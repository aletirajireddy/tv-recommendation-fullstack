# TV Dashboard Environment Configuration
# Copy this file to .env and configure for Local vs Cloud

# ==========================================
# SERVER CONFIGURATION
# ==========================================

# Port the Express Backend runs on (Default 3000)
PORT=3000

# Node Environment (development | production)
NODE_ENV=production

# App Identity (local | cloud)
APP_ENV=local

# ==========================================
# FRONTEND CONFIGURATION 
# ==========================================

# Port the Vite server runs on in development (Default 5173)
# Note: In Cloud Production, Nginx or Tailscale Funnel will handle port 80/443.
# Vite runs locally on 5173.
VITE_API_BASE_URL=/api

# ==========================================
# EXTERNAL INTEGRATIONS
# ==========================================

# Telegram Bot Token (if disabled, leave blank)
TELEGRAM_BOT_TOKEN=
# Telegram Target Chat ID
TELEGRAM_CHAT_ID=
# Master Switch
TELEGRAM_ENABLED=true

# ==========================================
# MCP SERVER v3 — Agentic Edition
# ==========================================

# Port the MCP server listens on
MCP_PORT=3001

# Vite port (if different from default 5173)
VITE_PORT=5173

# ── Auth (bearer token gate) ──────────────────────────────────────────────────
# MCP_AUTH_MODE=disabled  → open access (safe for local + Tailscale-only)
# MCP_AUTH_MODE=bearer    → require Authorization: Bearer <token>
#
# When enabling bearer mode:
#   1. Generate a token:
#      node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#   2. Paste the output below as MCP_AUTH_TOKEN
#   3. Give the same token to each AI client (Claude Desktop, Cursor, n8n …)
#      in their connector config under "Authorization: Bearer <token>"
#
MCP_AUTH_MODE=disabled
MCP_AUTH_TOKEN=

# ── Optional: pm2 remote deploy (pm2 deploy ecosystem.config.js production) ───
# Only needed if you want to push from your local machine to the VM over SSH
# without manually sshing in. Leave blank otherwise.
DEPLOY_USER=ubuntu
DEPLOY_HOST=YOUR_VM_IP_OR_HOSTNAME
DEPLOY_PATH=/home/ubuntu/tv-dashboard

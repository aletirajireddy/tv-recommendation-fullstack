# TV Dashboard Environment Configuration
# Copy this file to .env and configure for Local vs Cloud

# ==========================================
# SERVER CONFIGURATION
# ==========================================

# Port the Express Backend runs on (Default 3000)
PORT=3000

# Node Environment (development | production)
NODE_ENV=production

# ==========================================
# FRONTEND CONFIGURATION 
# ==========================================

# Port the Vite server runs on in development (Default 5173)
# Note: In Cloud Production, Nginx or Tailscale Funnel will handle port 80/443.
# Vite runs locally on 5173.
VITE_API_BASE_URL=/api

# ==========================================
# EXTERNAL INTEGRATIONS
# ==========================================

# Telegram Bot Token (if disabled, leave blank)
TELEGRAM_BOT_TOKEN=
# Telegram Target Chat ID
TELEGRAM_CHAT_ID=

# ==========================================
# MCP SERVER (AI Bridge)
# ==========================================

# Port the MCP SSE Server runs on
MCP_PORT=3001
